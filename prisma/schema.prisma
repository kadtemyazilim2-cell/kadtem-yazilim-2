// schema.prisma

datasource db {
  provider = "postgresql"
  url = env("POSTGRES_PRISMA_URL") // uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // uses a direct connection
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  MANAGER
  SITE_MANAGER
  USER
}

enum Status {
  ACTIVE
  INACTIVE
  COMPLETED     // For Site
  MAINTENANCE   // For Vehicle
  SOLD          // For Vehicle
  PASSIVE       // For Vehicle
  LEFT          // For Personnel
  DELETED       // For Correspondence
}

// -----------------------------------------------------------------------------
// USER & AUTH
// -----------------------------------------------------------------------------

model User {
  id                String   @id @default(cuid())
  name              String
  username          String   @unique
  password          String?  // Hashed
  email             String?
  role              Role     @default(USER)
  avatarUrl         String?
  editLookbackDays  Int?     @default(0)
  status            Status   @default(ACTIVE)
  
  // Relations
  permissions       Json?    // Stores Record<string, string[]>
  
  // Many-to-Many via Join Tables or Implicit
  assignedCompanies Company[] 
  assignedSites     Site[]

  // Audit Relations
  createdCorrespondences Correspondence[] @relation("CreatedCorrespondence")
  deletedCorrespondences Correspondence[] @relation("DeletedCorrespondence")
  
  createdTransactions    CashTransaction[] @relation("CreatedTransaction")
  responsibleTransactions CashTransaction[] @relation("ResponsibleTransaction")
  approvedTransactions   CashTransaction[] @relation("ApprovedTransaction")
  
  filledFuelLogs         FuelLog[]         @relation("FilledFuel")
  createdFuelTransfers   FuelTransfer[]    @relation("CreatedTransfer")
  
  createdPersonnelAttendance PersonnelAttendance[]
  createdVehicleAttendance   VehicleAttendance[]
  siteLogs                   SiteLogEntry[]    @relation("SiteLogAuthor")
}

// -----------------------------------------------------------------------------
// CORE ENTITIES
// -----------------------------------------------------------------------------

model Company {
  id          String   @id @default(cuid())
  name        String
  logoUrl     String?
  address     String?
  status      Status   @default(ACTIVE)
  stamp       String?  // Base64
  letterhead  String?  // Base64
  taxNumber   String?
  phone       String?
  
  // SMTP Config (Embedded)
  smtpHost      String?
  smtpPort      Int?
  smtpSecure    Boolean?
  smtpUser      String?
  smtpPass      String?
  smtpFromEmail String?
  smtpFromName  String?
  
  // Document Numbering
  currentDocumentNumber Int? @default(1)
  shortName             String? // [NEW]
  
  // Relations
  sites           Site[]    @relation("SiteCompany")
  sitePartners    SitePartner[]
  users           User[]
  vehicles        Vehicle[]
  correspondences Correspondence[]
}

model Site {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation("SiteCompany", fields: [companyId], references: [id])
  
  name        String
  location    String?
  status      Status   @default(ACTIVE) // ACTIVE, INACTIVE, COMPLETED
  
  // Construction Details
  workGroup             String?


  orderNo               String?
  projectNo             String?
  registrationNo        String?
  announcementDate      DateTime?
  tenderDate            DateTime?
  contractDate          DateTime?
  siteDeliveryDate      DateTime?
  
  contractYiUfe         Float?   // Index value
  priceDifferenceCoefficient Float?
  contractPrice         Float?
  realizedAmount        Float?
  kdv                   Float?

  priceDifference             Float?
  contractToCurrentUfeRatio   Float?
  currentUfeDate              DateTime?
  currentWorkExperienceAmount Float?


  provisionalAcceptanceDate DateTime?
  finalAcceptanceDate       DateTime?
  workExperienceCertificate String?
  
  completionDate        DateTime?
  extendedDate          DateTime?
  statusDetail          String?
  
  partnershipPercentage Float?
  provisionalAcceptanceDoc String?
  finalAcceptanceDoc       String?
  workExperienceDoc        String?
  // similarWorkGroup         String?  // [REMOVED] in favor of Relation
  // similarWorkExperienceAmount Float? // [REMOVED] in favor of Relation
  similarWorks             SimilarWorkItem[] // [NEW] Relation

  note                     String?
  personnelCount           Int?     @default(0)

  // Join Venture Partners (Multiple)
  partners        SitePartner[]

  users           User[]
  personnel       Personnel[]
  vehicles        Vehicle[]   @relation("PrimarySite")
  activeVehicles  Vehicle[]   @relation("AssignedSites") // Many-to-Many for multi-assignment
  
  fuelTanks       FuelTank[]
  fuelLogs        FuelLog[]
  transactions    CashTransaction[]
  logs            SiteLogEntry[]
  correspondences Correspondence[]
}

// -----------------------------------------------------------------------------
// ASSETS (VEHICLES, PERSONNEL)
// -----------------------------------------------------------------------------

enum VehicleType {
  TRUCK
  LORRY
  CAR
  EXCAVATOR
  TRACTOR
  MOTORCYCLE
  PICKUP
  OTHER
}

enum Ownership {
  OWNED
  RENTAL
}

model Vehicle {
  id              String      @id @default(cuid())
  companyId       String
  company         Company     @relation(fields: [companyId], references: [id])
  
  plate           String      @unique
  brand           String
  model           String
  year            Int
  type            VehicleType
  meterType       String      // KM or HOURS
  currentKm       Float
  
  status          Status      @default(ACTIVE)
  ownership       Ownership   @default(OWNED)
  
  // Insurance
  insuranceExpiry DateTime?
  insuranceStartDate DateTime?
  kaskoExpiry     DateTime?
  kaskoStartDate  DateTime?
  inspectionExpiry DateTime?
  lastInspectionDate DateTime?
  
  insuranceAgency String?
  insuranceCompany String?
  kaskoAgency     String?
  kaskoCompany    String?
  
  insuranceCost   Float?
  kaskoCost       Float?
  
  // Rental Info
  rentalCompanyName String?
  monthlyRentalFee  Float?
  rentalContact     String?
  
  // Details
  engineNumber    String?
  chassisNumber   String?
  fuelType        String?
  licenseFile     String? // Base64
  
  // Assignment
  assignedSiteId  String?
  assignedSite    Site?   @relation("PrimarySite", fields: [assignedSiteId], references: [id])
  
  assignedSites   Site[]  @relation("AssignedSites")
  
  // Relations
  fuelLogs        FuelLog[]
  attendance      VehicleAttendance[]
  transfersIn     FuelTransfer[] @relation("VehicleTo")
  transfersOut    FuelTransfer[] @relation("VehicleFrom")
}

model Personnel {
  id          String   @id @default(cuid())
  fullName    String
  role        String
  tcNumber    String?
  profession  String?
  salary      Float?
  category    String   // TECHNICAL, FIELD
  status      Status   @default(ACTIVE)
  
  siteId      String?
  site        Site?    @relation(fields: [siteId], references: [id])
  
  leftDate    DateTime?
  startDate   DateTime?
  note        String?
  
  // Relations
  attendance  PersonnelAttendance[]
}

// -----------------------------------------------------------------------------
// OPERATIONAL LOGS
// -----------------------------------------------------------------------------

model PersonnelAttendance {
  id          String   @id @default(cuid())
  personnelId String
  personnel   Personnel @relation(fields: [personnelId], references: [id])
  
  siteId      String
  date        DateTime
  
  status      String   // WORK, LEAVE, SICK, ABSENT...
  hours       Float
  overtime    Float?
  note        String?
  weather     String?
  
  createdByUserId String?
  createdByUser   User?   @relation(fields: [createdByUserId], references: [id])
}

model VehicleAttendance {
  id          String   @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  
  siteId      String
  date        DateTime
  
  status      String   // WORK, IDLE, REPAIR...
  hours       Float
  note        String?
  
  createdByUserId String?
  createdByUser   User?   @relation(fields: [createdByUserId], references: [id])
}

model FuelTank {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id])
  name        String
  capacity    Float
  currentLevel Float
  status      Status   @default(ACTIVE)
  
  // Relations
  transfersIn  FuelTransfer[] @relation("TankTo")
  transfersOut FuelTransfer[] @relation("TankFrom")
  logs         FuelLog[]      @relation("TankSource")
}

model FuelLog {
  id          String   @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id])
  
  tankId      String?
  tank        FuelTank? @relation("TankSource", fields: [tankId], references: [id])
  
  date        DateTime
  liters      Float
  cost        Float
  unitPrice   Float?
  mileage     Float
  fullTank    Boolean
  description String?
  
  filledByUserId String
  filledByUser   User   @relation("FilledFuel", fields: [filledByUserId], references: [id])
}

model FuelTransfer {
  id          String   @id @default(cuid())
  
  date        DateTime
  amount      Float
  unitPrice   Float?
  totalCost   Float?
  description String?
  
  // From
  fromType    String   // TANK, VEHICLE, EXTERNAL
  fromId      String   // ID or Name
  fromTank    FuelTank? @relation("TankFrom", fields: [fromTankId], references: [id])
  fromTankId  String?
  fromVehicle Vehicle?  @relation("VehicleFrom", fields: [fromVehicleId], references: [id])
  fromVehicleId String?
  
  // To
  toType      String   // TANK, VEHICLE
  toId        String
  toTank      FuelTank? @relation("TankTo", fields: [toTankId], references: [id])
  toTankId    String?
  toVehicle   Vehicle?  @relation("VehicleTo", fields: [toVehicleId], references: [id])
  toVehicleId String?
  
  createdByUserId String
  createdByUser   User   @relation("CreatedTransfer", fields: [createdByUserId], references: [id])
}

model SiteLogEntry {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id])
  
  date        DateTime
  weather     String?
  temperature Float?
  content     String   // Markdown
  
  authorId    String
  author      User     @relation("SiteLogAuthor", fields: [authorId], references: [id])
  
  tags        String[]
  images      String[]
}

// -----------------------------------------------------------------------------
// FINANCIAL & OFFICE
// -----------------------------------------------------------------------------

model CashTransaction {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id])
  
  date        DateTime
  type        String   // INCOME, EXPENSE
  category    String
  amount      Float
  description String
  documentNo  String?
  
  responsibleUserId String?
  responsibleUser   User?   @relation("ResponsibleTransaction", fields: [responsibleUserId], references: [id])
  
  createdByUserId   String
  createdByUser     User    @relation("CreatedTransaction", fields: [createdByUserId], references: [id])
  
  approvedByUserId  String?
  approvedByUser    User?   @relation("ApprovedTransaction", fields: [approvedByUserId], references: [id])
  
  createdAt   DateTime @default(now())
}

model Correspondence {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  
  siteId      String?
  site        Site?    @relation(fields: [siteId], references: [id])

  date        DateTime
  direction   String   // INCOMING, OUTGOING
  type        String   // OFFICIAL, INTERNAL...
  subject     String
  description String
  referenceNumber String?
  senderReceiver String
  senderReceiverAlignment String? // left, center, right
  
  interest    String[]
  appendices  String[]
  registrationNumber String?
  
  attachmentUrls String[]
  
  createdByUserId String
  createdByUser   User   @relation("CreatedCorrespondence", fields: [createdByUserId], references: [id])
  
  status      Status   @default(ACTIVE)
  
  deletedByUserId String?
  deletedByUser   User?   @relation("DeletedCorrespondence", fields: [deletedByUserId], references: [id])
  deletionReason  String?
  deletionDate    DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  includeStamp Boolean @default(false) // [NEW]
}

model YiUfeRate {
  id    String @id @default(cuid())
  year  Int
  month Int
  index Float
  
  @@unique([year, month])
}

model Institution {
  id          String   @id @default(cuid())
  name        String
  category    String? // BANK, INSURANCE...
  alignment   String? // left, center, right
  email       String?
  phone       String?
  mobile      String?
  contactPerson String?
  shortName     String? // [NEW]
}

model SitePartner {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  percentage Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SimilarWorkItem {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  
  group       String   // e.g. A-I, B-II
  code        String?  // e.g. III
  amount      Float?   // Experience Amount
}
